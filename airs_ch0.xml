<root>
    <type>spectrometer</type>
    <wl_min unit="micron"> 1.95 </wl_min>
    <wl_max unit="micron"> 3.90 </wl_max>
    <targetR>100</targetR>
    <spectral_binning_task> EstimateSpectralBinning </spectral_binning_task>

    <optical_path>
        <opticalElement>D1
            <type>filter</type>
            <task_model>LoadOpticalElementHDF5</task_model>
            <temperature unit='K'>60</temperature>
            <hdf5_file>__MPDBdata__</hdf5_file>
            <group_key>optics/d1</group_key>
            <wavelength_key>wavelength</wavelength_key>
            <emissivity_key>emissivity</emissivity_key>
            <efficiency_key>transmission.eol</efficiency_key>
        </opticalElement>
        <opticalElement>D2
            <type>filter</type>
            <task_model>LoadOpticalElementHDF5</task_model>
            <temperature unit='K'>60</temperature>
            <hdf5_file>__MPDBdata__</hdf5_file>
            <group_key>optics/d2</group_key>
            <wavelength_key>wavelength</wavelength_key>
            <emissivity_key>emissivity</emissivity_key>
            <efficiency_key>reflectivity.eol</efficiency_key>
        </opticalElement>
        <opticalElement>COM_M6
            <type>surface</type>
            <task_model>LoadOpticalElementHDF5</task_model>
            <temperature unit='K'>60</temperature>
            <hdf5_file>__MPDBdata__</hdf5_file>
            <group_key>optics/m6</group_key>
            <wavelength_key>wavelength</wavelength_key>
            <emissivity_key>emissivity</emissivity_key>
            <efficiency_key>reflectivity.eol</efficiency_key>
        </opticalElement>
        <opticalElement>COM_M7CH0
            <type>surface</type>
            <task_model>LoadOpticalElementHDF5</task_model>
            <temperature unit='K'>60</temperature>
            <hdf5_file>__MPDBdata__</hdf5_file>
            <group_key>optics/m7_ch0</group_key>
            <wavelength_key>wavelength</wavelength_key>
            <emissivity_key>emissivity</emissivity_key>
            <efficiency_key>reflectivity.eol</efficiency_key>
        </opticalElement>
        <opticalElement>S-CH0
            <type>slit</type>
            <width unit="mm">1.07</width>
        </opticalElement>
        <opticalElement>AIRS-CH0-Db1-L1
            <type>surface</type>
            <task_model>LoadOpticalElementHDF5</task_model>
            <temperature unit='K'>60</temperature>
            <hdf5_file>__MPDBdata__</hdf5_file>
            <group_key>ch0/db1_l1</group_key>
            <wavelength_key>wavelength</wavelength_key>
            <emissivity_key>emissivity</emissivity_key>
            <efficiency_key>transmission.eol</efficiency_key>
        </opticalElement>
        <opticalElement>AIRS-CH0-Db1-L2
            <type>surface</type>
            <task_model>LoadOpticalElementHDF5</task_model>
            <temperature unit='K'>60</temperature>
            <hdf5_file>__MPDBdata__</hdf5_file>
            <group_key>ch0/db1_l2</group_key>
            <wavelength_key>wavelength</wavelength_key>
            <emissivity_key>emissivity</emissivity_key>
            <efficiency_key>transmission.eol</efficiency_key>
        </opticalElement>
        <opticalElement>AIRS-CH0-PR1
            <type>surface</type>
            <task_model>LoadOpticalElementHDF5</task_model>
            <temperature unit='K'>60</temperature>
            <hdf5_file>__MPDBdata__</hdf5_file>
            <group_key>ch0/pr1</group_key>#
            <wavelength_key>wavelength</wavelength_key>
            <emissivity_key>emissivity</emissivity_key>
            <efficiency_key>transmission.eol</efficiency_key>
        </opticalElement>
        <opticalElement> AIRS_CH0_M1
            <type>surface</type>
            <task_model>LoadOpticalElementHDF5</task_model>
            <temperature unit='K'>60</temperature>
            <hdf5_file>__MPDBdata__</hdf5_file>
            <group_key>ch0/m1</group_key>
            <wavelength_key>wavelength</wavelength_key>
            <emissivity_key>emissivity</emissivity_key>
            <efficiency_key>reflectivity.eol</efficiency_key>
        </opticalElement>
        <opticalElement>AIRS-CH0-Db2-L1
            <type>surface</type>
            <task_model>LoadOpticalElementHDF5</task_model>
            <temperature unit='K'>60</temperature>
            <hdf5_file>__MPDBdata__</hdf5_file>
            <group_key>ch0/db2_l1</group_key>
            <wavelength_key>wavelength</wavelength_key>
            <emissivity_key>emissivity</emissivity_key>
            <efficiency_key>transmission.eol</efficiency_key>
        </opticalElement>
        <opticalElement>AIRS-CH0-Db2-L2
            <type>surface</type>
            <task_model>LoadOpticalElementHDF5</task_model>
            <temperature unit='K'>60</temperature>
            <hdf5_file>__MPDBdata__</hdf5_file>
            <group_key>ch0/db2_l2</group_key>
            <wavelength_key>wavelength</wavelength_key>
            <emissivity_key>emissivity</emissivity_key>
            <efficiency_key>transmission.eol</efficiency_key>
        </opticalElement>
        <opticalElement>enclosure
            <type>optics box</type>
            <task_model>LoadOpticalElement</task_model>
            <temperature unit='K'>55</temperature>
            <datafile>__ConfigPath__/payload_data/black_box.ecsv</datafile>
            <wavelength_key>wavelength</wavelength_key>
            <emissivity_key>emissivity</emissivity_key>
            <efficiency_key>transmission_eol</efficiency_key>
            <solid_angle>pi-omega_pix</solid_angle>
        </opticalElement>
        <opticalElement>detector
            <type>detector box</type>
            <task_model>LoadOpticalElement</task_model>
            <temperature unit='K'>42</temperature>
            <datafile>__ConfigPath__/payload_data/black_box.ecsv</datafile>
            <wavelength_key>wavelength</wavelength_key>
            <emissivity_key>emissivity</emissivity_key>
            <efficiency_key>transmission_eol</efficiency_key>
            <solid_angle>pi</solid_angle>
        </opticalElement>
    </optical_path>

    <qe>
        <responsivity_task>LoadResponsivity</responsivity_task>
        <datafile>__ConfigPath__/payload_data/QE_20220705.ecsv</datafile>
    </qe>

    <Fnum_x>15.5</Fnum_x>
    <Fnum_y>15.5</Fnum_y>

    <detector>
        <plate_scale>
            <spatial unit="mas/micron"> 11.33 </spatial>
            <spectral unit="mas/micron"> 17.31 </spectral>
        </plate_scale>
        <delta_pix unit="micron"> 18.0 </delta_pix>
        <spatial_pix>64</spatial_pix>
        <spectral_pix>356</spectral_pix>

        <well_depth unit="count"> 85000  </well_depth>
        <f_well_depth unit=""> 1.0 </f_well_depth>

        <add_foregrounds_to_se> True </add_foregrounds_to_se>

        <!-- <qe_map_task> LoadQeMap </qe_map_task>
        <qe_map_filename> __ConfigPath__/payload_data/qe_map.h5 </qe_map_filename> -->

<!--        ### the following are test values! ###-->

        <saturation> False </saturation>
        <sat_task> ApplySimpleSaturation </sat_task>

        <pixel_non_linearity> False </pixel_non_linearity>
        <pnl_task> ApplyPixelsNonLinearity </pnl_task>
        <pnl_map_task> LoadPixelsNonLinearityMapNumpy </pnl_map_task>
        <pnl_filename> /home/ariel/lorenzo.mugnai/USER_DATA/ExoSim/20231009-DataChallenge/out/linear_coeff/linear_coeff_AIRS-CH0_7.npy</pnl_filename>

        <gain_drift> False </gain_drift>
        <gain_drift_task> AddGainDrift </gain_drift_task>
        <gain_drift_amplitude_range_min> 0.9e-3 </gain_drift_amplitude_range_min>
        <gain_drift_amplitude_range_max> 0.11e-2 </gain_drift_amplitude_range_max>
        <gain_coeff_order_t> 5 </gain_coeff_order_t>
        <gain_coeff_t_min> -1.0 </gain_coeff_t_min>
        <gain_coeff_t_max> 1.0 </gain_coeff_t_max>
        <gain_coeff_order_w> 5 </gain_coeff_order_w>
        <gain_coeff_w_min> -1.0 </gain_coeff_w_min>
        <gain_coeff_w_max> 1.0 </gain_coeff_w_max>

        <dead_pixels> False </dead_pixels>
        <dp_map_task> ApplyDeadPixelMapNumpy </dp_map_task>
        <dp_map_filename> /home/ariel/lorenzo.mugnai/USER_DATA/ExoSim/20231009-DataChallenge/out/dead_pixels/dead_pixels_AIRS-CH0_7.npy </dp_map_filename>

        <cosmic_rays> False </cosmic_rays>
        <cosmic_rays_task> AddCosmicRays </cosmic_rays_task>
        <cosmic_rays_rate unit="ct/(cm^2 * s)"> 5.5 </cosmic_rays_rate>
        <saturation_rate> 0.01 </saturation_rate>
        <interaction_shapes>
            <single> 0.89 </single>
            <line_v> 0.05 </line_v>
            <line_h> 0.05 </line_h>
            <square> 0.01 </square>
        </interaction_shapes>

        <dark_current> False </dark_current>
        <dc_task> AddConstantDarkCurrent </dc_task>
        <dc_mean unit="ct/s"> 0.1 </dc_mean>

        <shot_noise> False </shot_noise>

        <ktc_offset> False </ktc_offset>
        <ktc_offset_task> AddKTC </ktc_offset_task>
        <ktc_sigma unit="ct"> 10 </ktc_sigma>

        <read_noise> False </read_noise>
        <read_noise_task> AddNormalReadNoise </read_noise_task>
        <read_noise_sigma unit="ct"> 15.6 </read_noise_sigma>

        <ADC>False</ADC>
        <ADC_num_bit> 16 </ADC_num_bit>
        <ADC_gain> 0.4369 </ADC_gain>
        <ADC_offset> -1000 </ADC_offset>

<!--        ### here te test values end ###-->

    </detector>


    <wl_solution>
        <wl_solution_task>LoadWavelengthSolution</wl_solution_task>
        <datafile>__ConfigPath__/payload_data/AIRS-CH0-wl_sol.ecsv</datafile>
        <center>auto</center>
    </wl_solution>

    <psf>
        <!--        <shape>Airy</shape>-->
        <psf_task>LoadPsfPaos</psf_task>
        <filename>__ConfigPath__/payload_data/PAOS/20250108_200nm_defocus/data/AIRS-CH0/Ariel_AIRS-CH0.h5 </filename>
    </psf>

    <readout>
        <readout_frequency unit="Hz">10</readout_frequency>
        <n_NRDs_per_group> 1 </n_NRDs_per_group>
        <n_groups> 2 </n_groups>
        <n_sim_clocks_Ground> 10 </n_sim_clocks_Ground>
        <n_sim_clocks_first_NDR> 1 </n_sim_clocks_first_NDR>
        <n_sim_clocks_NDR> 1 </n_sim_clocks_NDR>
        <n_sim_clocks_Reset> 10 </n_sim_clocks_Reset>
        <n_sim_clocks_groups> 6000 </n_sim_clocks_groups>
        <n_exposures> 1 </n_exposures>
    </readout>

    <radiometric>
        <aperture_photometry>
<!--            <spectral_mode> wl_solution </spectral_mode>-->
<!--            <spatial_mode> column </spatial_mode>-->
            <!-- <apertures_task> EstimateApertures </apertures_task>
            <auto_mode> bin </auto_mode>
            <EnE> 0.91 </EnE> -->
            <apertures_task> LoadApertures </apertures_task>
            <file_name> __ConfigPath__/payload_data/apertures/20250506/AIRS-CH0_apertures.csv </file_name>
        </aperture_photometry>
        <photon_margin>0.41</photon_margin>
        <optimal_photometry> True </optimal_photometry>

        <noise_floor>
            <noise_level scale="1e-6">20</noise_level>
        </noise_floor>
        <jitter_floor>
            <noise_level scale="1e-6">20</noise_level>
        </jitter_floor>

        <dark_current> True </dark_current>
        <read_noise> True </read_noise>

        <custom_noise> additive
            <task>__TaskFolder__/compute_additive_noise.py</task>
            <scale>0.3</scale>
            <reference_noise>read_noise</reference_noise>
            <comment> Additive noise is proportional to Read Noise (R-PRD-8811) </comment>
        </custom_noise>


        <custom_noise> gain
            <noise_level scale="1e-6">40</noise_level>
        </custom_noise>
    </radiometric>
</root>
